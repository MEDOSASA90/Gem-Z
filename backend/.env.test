# GEM Z — Test Environment Variables
# Used by Jest test suite via dotenv/config in setup.ts

NODE_ENV=test
DATABASE_URL="postgresql://test_user:test_pass@localhost:5433/gemz_test_db"
JWT_SECRET="test-jwt-secret-minimum-32-characters-long-for-testing"
REFRESH_SECRET="test-refresh-secret-minimum-32-characters-long-for-testing"
OPENAI_API_KEY="sk-test-key-for-testing-only"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="test@gemz.app"
SMTP_PASS="test-smtp-password"
SMTP_FROM="Gem Z Test <noreply@gemz.app>"

# Redis
REDIS_URL="redis://localhost:6379/1"

# CORS
CLIENT_URL="http://localhost:3000"
API_URL="http://localhost:5000"

# Web Push
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""
