{
  "name": "gem-z-backend",
  "version": "1.0.0",
  "description": "Backend API for GEM Z",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --transpile-only src/index.ts",
    "start": "node dist/migrate.js && node dist/index.js",
    "db:migrate": "knex migrate:latest",
    "db:migrate:make": "knex migrate:make",
    "db:seed": "knex seed:run",
    "db:seed:make": "knex seed:make",
    "db:rollback": "knex migrate:rollback",
    "db:reset": "npm run db:rollback -- --all && npm run db:migrate && npm run db:seed",
    "db:status": "knex migrate:status",
    "lint": "tsc --noEmit",
    "docs:postman": "ts-node scripts/generate-postman.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration"
  },
  "dependencies": {
    "@bull-board/api": "^6.0.0",
    "@bull-board/express": "^6.0.0",
    "@bull-board/ui": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@faker-js/faker": "^8.4.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.27.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "yamljs": "^0.3.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/yamljs": "^0.2.34",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5"
  }
}