# ==========================================
# GEM Z - Environment Variables Example
# Version 5.0 - Enterprise Specification
# ==========================================

# ------------------------------------------
# App
# ------------------------------------------
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ------------------------------------------
# Database - PostgreSQL 16
# ------------------------------------------
DATABASE_URL=postgresql://gemz:gemz_secret@localhost:5432/gemz
POSTGRES_USER=gemz
POSTGRES_PASSWORD=gemz_secret
POSTGRES_DB=gemz

# ------------------------------------------
# Cache - Redis 7
# ------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------
# Analytics - ClickHouse
# ------------------------------------------
CLICKHOUSE_URL=http://localhost:8123

# ------------------------------------------
# Search - Elasticsearch 8
# ------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200

# ------------------------------------------
# JWT Configuration
# ------------------------------------------
JWT_SECRET=change_me_to_a_very_long_random_string_min_64_chars_recommended_for_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ------------------------------------------
# Security
# ------------------------------------------
BCRYPT_ROUNDS=12
MFA_ISSUER=GEMZ

# ------------------------------------------
# Rate Limiting
# ------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
