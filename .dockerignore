# =============================================================================
# GEM Z — Docker Build Context Ignore Rules
# Prevents unnecessary files from being sent to Docker daemon
# =============================================================================

# ─── Git ─────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Build Outputs ───────────────────────────────────────────────────────────
.next
dist
build
*.tsbuildinfo

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage
.nyc_output
*.test.ts
*.test.js
*.spec.ts
*.spec.js
jest.config.*
__tests__
__mocks__

# ─── Documentation ───────────────────────────────────────────────────────────
README.md
CHANGELOG.md
VISUAL_IDENTITY.md
ARCHITECTURE.md
*.md
docs/

# ─── CI/CD ───────────────────────────────────────────────────────────────────
.github
.gitlab-ci.yml
Jenkinsfile

# ─── Docker ──────────────────────────────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore
nginx/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.log
logs/
tmp/
temp/
cache/
.eslintcache
.stylelintcache

# ─── Backend Specific ────────────────────────────────────────────────────────
backend/node_modules
t_errors.txt
seed.js
replace_logo.js
run_v3.mjs

# ─── Frontend Specific ───────────────────────────────────────────────────────
frontend/node_modules
frontend/*.zip
frontend/fix*.js
frontend/fix*.mjs
frontend/import_*.mjs
frontend/i18n_extractor.mjs
frontend/link_mapper.mjs
frontend/super_link_mapper.mjs
frontend/missing_*.json
frontend/unfix_link.mjs
frontend/undo_numerals.js
frontend/update.js
frontend/seed_pricing.sql
